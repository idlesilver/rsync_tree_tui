{
  "auto_update": {
    "enabled": true,
    "latest_checked_at": "",
    "latest_version": "",
    "last_prompted_at": "",
    "last_prompted_version": "",
    "skipped_version": ""
  },
  "checksum_policy": {
    "checksum_suffixes": [
      ".json",
      ".yaml",
      ".yml",
      ".txt",
      ".py",
      ".sh",
      ".md"
    ],
    "mode": "balanced",
    "size_threshold_mb": 512
  },
  "diff_viewers": [
    "vim -d {local} {remote}",
    "vimdiff {local} {remote}",
    "nvim -d {local} {remote}"
  ],
  "known_connections": [
    {
      "id": "example1",
      "local_root": "/abs/local/path",
      "permission_group": "shared",
      "remote": "user@host:/abs/remote/path",
      "trigger_count": 1
    }
  ],
  "permission_group": "",
  "version": 1
}
